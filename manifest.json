{
  "manifest_version": "0.3",
  "name": "conduyt-crm-pp-mcp",
  "display_name": "Conduyt CRM",
  "version": "1.0.0",
  "description": "Full-coverage Conduyt CLI: every endpoint, plus Kloudi-grade send-safety forensics no other surface has.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/conduyt-crm-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/conduyt-crm-pp-mcp",
      "args": [],
      "env": {
        "CONDUYT_CRM_BEARER_AUTH": "${user_config.conduyt_crm_bearer_auth}"
      }
    }
  },
  "user_config": {
    "conduyt_crm_bearer_auth": {
      "type": "string",
      "title": "CONDUYT_CRM_BEARER_AUTH",
      "description": "Sets CONDUYT_CRM_BEARER_AUTH for the Conduyt CRM MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
